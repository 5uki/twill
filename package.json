{
  "name": "twill",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ci:android-build": "bunx tauri android build --debug --apk --target aarch64 --ci",
    "ci:ios-build": "bunx tauri ios build --debug --target aarch64-sim --ci",
    "ci:verify": "bun test && bun run build && cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features && cargo test --manifest-path src-tauri/Cargo.toml && cargo run --manifest-path src-tauri/Cargo.toml --bin twill-cli -- workspace bootstrap --format json",
    "ci:desktop-build": "bunx tauri build --debug --no-bundle --ci",
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "bun test",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.5",
    "@fluentui/react-icons": "^2.0.323",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "@tauri-apps/cli": "^2"
  }
}
